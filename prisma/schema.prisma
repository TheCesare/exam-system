generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Committee {
  id          String   @id @default(cuid())
  title       String
  description String?
  memberName  String
  memberPhone String?
  status      String   @default("pending") // pending, in_progress, completed, rejected
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}