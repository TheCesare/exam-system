generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Teacher {
  id        String   @id @default(cuid())
  name      String
  subject   String
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScheduleCell {
  id        String @id @default(cuid())
  grade     String
  day       String
  committees Int    @default(0)
  subject   String @default("")
  time      String @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([grade, day])
}

model DistributionResult {
  id        String   @id @default(cuid())
  data      String   // JSON blob of assignments + tracking
  createdAt DateTime @default(now())
}